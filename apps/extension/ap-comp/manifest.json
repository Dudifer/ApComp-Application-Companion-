{
  "manifest_version": 3,
  "name": "ApComp — Save Job",
  "version": "0.1.0",
  "description": "Capture the job posting on the current tab and add it to your ApComp dashboard.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Save this job to ApComp",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/extractors/index.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": []
}
