{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting — loosened so unused imports / implicit any don't block the build */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    /* Workspace package paths */
    "paths": {
      "@apcomp/types": ["../../packages/types/src"],
      "@apcomp/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/__test__", "src/__mocks__", "src/stories", "src/pages/ResumeDemoPage.tsx"]
}
