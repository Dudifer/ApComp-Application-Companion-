generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cvProfile      CvProfile?
  applications   Application[]
  savedJobs      SavedJob[]
  dismissedJobs  DismissedJob[]
  processedEmails ProcessedEmail[]
  jobFeedWeights JobFeedWeights?
  userSettings   UserSettings?
  gmailToken     GmailToken?
  jobInteractions JobInteraction[]
  recLab2Interactions RecLab2Interaction[]

  @@map("users")
}

model UserSettings {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastScrapedAt DateTime?

  @@map("user_settings")
}

model CvProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name    String?
  email   String?
  rawText String? @db.Text

  // Store structured data as JSON
  roles        Json    @default("[]")
  projects     Json    @default("[]")
  skills       Json    @default("[]")
  practices    Json    @default("[]")
  education    Json    @default("[]")
  gapQuestions Json    @default("[]")
  isComplete   Boolean @default(false)

  // ── Recommendation embeddings (Rec Lab / embedding-based matching) ──────
  // Computed from CV title history and role/project descriptions (skills
  // text is folded into the description text, see text.ts). Free, local
  // model (Xenova/all-MiniLM-L6-v2, 384 dims) via EmbeddingService — see
  // apps/api/src/modules/rec-lab/embedding.service.ts.
  titleEmbedding       Float[] @default([])
  descriptionEmbedding Float[] @default([])
  // Deprecated — always [] now. Left in place to avoid another migration on
  // top of the existing drift history; safe to drop in a future migration.
  skillsEmbedding      Float[] @default([])
  embeddingSourceHash  String? // hash of the text last embedded, so we skip recompute when nothing changed
  embeddingUpdatedAt   DateTime?

  // Rec Lab 2's "sort recommended jobs by CV similarity, once per CV
  // upload" feature. recLab2SortHash records which CV embeddingSourceHash
  // recLab2JobOrder (the actual sorted list of job ids) was computed
  // against — a fresh CV upload changes embeddingSourceHash once
  // re-embedded, so this naturally goes stale with no separate reset step.
  // Deliberately persists the real computed order, not just a "sorted:
  // yes/no" boolean — if that boolean were the only record, a request that
  // gets cancelled after the flag is written but before the client sees the
  // sorted response would leave future loads permanently skipping the sort
  // while still displaying the unsorted fallback order.
  recLab2SortHash  String?
  recLab2JobOrder  Json    @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cv_profiles")
}

model Application {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  company String
  role    String
  status  ApplicationStatus @default(APPLIED)

  // Optional links
  jobUrl        String?
  jobExternalId String?
  jobSource     String? // 'adzuna' | 'jsearch'

  // Email tracking
  lastEmailSubject String?
  lastEmailDate    DateTime?
  // Gmail API message id for lastEmailSubject/lastEmailDate — lets the UI
  // deep-link to the actual email (https://mail.google.com/mail/u/0/#all/<id>)
  // instead of just showing the subject line. Nullable: older rows created
  // before this field existed, or applications created by other paths, won't
  // have one.
  lastEmailId      String?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("applications")
}

model SavedJob {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  externalId String
  source     String // 'adzuna' | 'jsearch'

  // Full job details as JSON
  jobData Json

  // Expiry — refresh after 7 days
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  savedAt DateTime @default(now())

  @@unique([userId, externalId, source])
  @@map("saved_jobs")
}

model DismissedJob {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId   String
  source  String
  company String
  title   String
  reason  String?

  dismissedAt DateTime @default(now())

  @@map("dismissed_jobs")
}

model JobFeedWeights {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  adzuna  Float @default(0.5)
  jsearch Float @default(0.5)

  updatedAt DateTime @updatedAt

  @@map("job_feed_weights")
}

// Cached embeddings for a job listing, keyed by the app's composite Job.id
// (e.g. "openjobdata-abc123", "manual-<hash>"). Recomputed lazily whenever
// `sourceHash` no longer matches the job's current title+description —
// jobs are otherwise immutable once fetched, so this is cheap to keep fresh.
model JobEmbedding {
  id     String @id @default(cuid())
  jobId  String @unique // composite Job.id
  source String
  externalId String

  title       String
  company     String?

  titleEmbedding       Float[]
  descriptionEmbedding Float[]
  // Deprecated — skills text is now folded into descriptionEmbedding (see
  // text.ts). Left in place (always []) to avoid another migration on top
  // of the existing drift history; safe to drop in a future migration.
  skillsEmbedding      Float[] @default([])

  // pgvector column — average of titleEmbedding/descriptionEmbedding (same
  // math as scoring.ts's compositeEmbedding()), stored as a real `vector`
  // type so Postgres can build an ANN index (ivfflat/HNSW) over it for real
  // nearest-neighbor retrieval at 1.4M-row scale. Prisma has no native
  // pgvector type, so this is `Unsupported` — read/write only via
  // $queryRaw/$executeRaw (see catalog-embedding.ts, rec-lab.service.ts).
  // Nullable so existing rows aren't invalidated; backfilled separately
  // (see scripts/backfill-composite-vector.ts).
  compositeVector Unsupported("vector(384)")?

  sourceHash String // hash of title+description, to detect staleness

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source, externalId])
  @@map("job_embeddings")
}

enum InteractionType {
  VIEWED          // shown in a recommendation/search batch, no action taken (yet)
  CLICKED         // opened the job detail panel
  SAVED
  APPLIED
  MORE_LIKE_THIS
  IGNORED         // shown repeatedly with no positive interaction
  DISMISSED
  LESS_LIKE_THIS
}

enum InteractionContext {
  RECOMMENDED
  SEARCH
}

// Every interaction a user has with a job, recommended or searched. This is
// the ledger the Rec Lab (and eventually the live feed) computes job scores
// from — scores are derived on read, not cached, so editing/removing a past
// interaction ("replay") immediately changes future ranking with no cache to
// invalidate. See rec-lab/scoring.ts for the weighting + decay logic.
model JobInteraction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId      String // composite Job.id
  source     String
  externalId String

  // Denormalized for display in the Rec Lab / timeline without a join back
  // to a job blob that may have expired out of SavedJob.
  jobTitle   String
  jobCompany String?

  type    InteractionType
  context InteractionContext @default(RECOMMENDED)

  // Weight applied at the time of the interaction (from the config in
  // scoring.ts). Stored so historical events don't silently reshuffle if the
  // weight table is retuned later — recompute explicitly if you want that.
  weight Float

  note String? // free-form, e.g. "replayed: was DISMISSED, changed to SAVED"

  createdAt DateTime @default(now())

  @@index([userId, jobId])
  @@index([userId, createdAt])
  @@map("job_interactions")
}

// Rec Lab 2's own interaction ledger — deliberately separate from
// JobInteraction/DismissedJob rather than reusing them. Those tables have
// real side effects elsewhere: a JobInteraction of type DISMISSED creates a
// DismissedJob row (RecLabService.setDismissed), which excludes the job from
// the *live* recommended-jobs feed, and JobInteraction rows feed directly
// into RecLabService.rank()'s interaction scoring for the original Rec Lab.
// Logging Rec Lab 2 test interactions into that same table would silently
// change live app behavior and the original Rec Lab's ranking — exactly
// what "shouldn't impact the job recommendation order yet" is guarding
// against. This table is scored (see scoring.ts's weightFor/
// aggregateInteractionScore, reused as-is) but nothing reads it for ranking
// yet — see RecLab2Service.
model RecLab2Interaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId      String // composite Job.id (e.g. "openjobdata-<catalogId>")
  jobTitle   String
  jobCompany String?

  type   InteractionType // same enum/weights as the original Rec Lab
  weight Float

  createdAt DateTime @default(now())

  @@index([userId, jobId])
  @@index([userId, createdAt])
  @@map("rec_lab2_interactions")
}

enum ApplicationStatus {
  APPLIED
  SUBMITTED
  VIEWED
  ASSESSMENT
  PHONE_SCREEN
  TECHNICAL
  INTERVIEW
  FINAL_ROUND
  OFFER
  REJECTED
  WITHDRAWN
  UNKNOWN
  DISMISSED
}

model ProcessedEmail {
  id        String   @id  // Gmail message ID
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  processedAt DateTime @default(now())

  @@map("processed_emails")
}

model GmailToken {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String?
  expiryDate   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("gmail_tokens")
}

// Full job catalog — lives on the laptop's local PostgreSQL, queried via jobs-server.ts
model JobCatalog {
  id              String    @id           // external dataset ID
  title           String
  company         String?
  country         String?
  city            String?
  state           String?
  locationDisplay String?
  isRemote        Boolean   @default(false)
  workplaceType   String?
  employmentType  String?
  postedAt        DateTime?
  applyUrl        String?
  department      String?
  description     String?   @db.Text
  status          String    @default("active")
  importedAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([isRemote])
  @@index([postedAt(sort: Desc)])
  @@map("job_catalog")
}
