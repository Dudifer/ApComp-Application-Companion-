# temp directory
.temp
.tmp

# sql backups
*.sql
# ...but not Prisma migration files — those are real, tracked source, not
# backups. Without this exception every migrations/*/migration.sql (and so
# the whole migration folder, since git doesn't track empty dirs) silently
# never gets committed.
!prisma/migrations/**/*.sql

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

/generated/prisma

#CloudFlare config
/cloudflared-config.yml
cloudflared-config.yml

/.job-cache
/.job-cache/*
email-parse-log.txt

# Local embedding model weights (~90MB) — downloaded once, cached here so
# pnpm install/rebuild doesn't wipe it. See embedding.service.ts.
/.model-cache