# apps/api/.env.production
# Copy this to .env on your EC2 instance and fill in all values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://apcomp_user:CHANGE_THIS_PASSWORD@localhost:5432/apcomp_db"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
DOMAIN=yourdomain.com

# ── Clerk Auth ────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...         # From Clerk dashboard → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_...    # Also needed in frontend .env

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://apcomp.us/applications/gmail/callback

# ── Job APIs ──────────────────────────────────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=

# ── Contact Discovery ─────────────────────────────────────────────────────────
HUNTER_API_KEY=


# ── apps/web/.env.production ──────────────────────────────────────────────────
# (set these as VITE_ prefixed vars so Vite bundles them into the frontend)

VITE_CLERK_PUBLISHABLE_KEY=pk_test_Y3VkZGx5LWRvbHBoaW4tMjguY2xlcmsuYWNjb3VudHMuZGV2JA
VITE_API_URL=https://apcomp.us/api
